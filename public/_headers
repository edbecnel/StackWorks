# Cloudflare Pages response headers.
#
# Vite content-hashes all bundled assets (JS, CSS, SVGs imported via ?url), so
# their filenames change whenever their content changes. These can be cached
# forever with the immutable directive - the browser will never need to
# revalidate them.
#
# HTML entry points are NOT hashed; they must always revalidate so users pick
# up new deployments immediately.

# Apply COOP + COEP to every response so clean URLs (/chess, /) are also
# cross-origin isolated. These are required for SharedArrayBuffer / WASM threads
# (Stockfish). More specific rules below override Cache-Control as needed.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Vite-bundled assets (JS chunks, CSS, imported SVG/image assets).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Stockfish WASM + worker (large, rarely changes, versioned in filename).
# Cross-Origin-Resource-Policy: cross-origin is required so that the Stockfish
# blob: bootstrap worker (opaque/null origin) can fetch these files under COEP.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

# Piece and icon images (not hashed, but change infrequently).
/pieces/*
  Cache-Control: public, max-age=2592000

/icons/*
  Cache-Control: public, max-age=2592000

# Splash screen (not hashed).
/splash.png
  Cache-Control: public, max-age=2592000

# Service Worker file must never be cached aggressively.
/sw.js
  Cache-Control: no-store

# HTML entry points - always revalidate.
/*.html
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate
